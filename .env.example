GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=
GARMINTOKENS=~/.garminconnect
# Optional one-shot MFA for non-interactive local runs:
# GARMIN_MFA=123456

# GitHub Actions: Gmail OAuth user JSON (gmail.readonly) for automatic Garmin MFA OTP
# GMAIL_OAUTH_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","token_uri":"https://oauth2.googleapis.com/token","scopes":["https://www.googleapis.com/auth/gmail.readonly"]}

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Paste full service-account JSON on one line, or use creds.json via scripts/run_local.sh
GOOGLE_CREDS_JSON=
GOOGLE_SHEET_NAME="Garmin BIA Data"

# Gmail OTP for CI / local unattended login (scripts/run_local.sh loads gmail_token.json)
# GMAIL_OAUTH_JSON=

USER_HEIGHT_CM=176
SYNC_TIMEZONE=Asia/Kolkata
SYNC_LOOKBACK_DAYS=2

# Optional: backfill a single day (YYYY-MM-DD); disables lookback
# SYNC_DATE=2026-06-02

# Telegram report: false/unset = decision format; true = legacy digest
# TELEGRAM_LEGACY_REPORT=false

# Lean-bulk weight-rate band for status icon (kg/week, default 0.10–0.20)
# WEIGHT_TARGET_MIN_KG=0.10
# WEIGHT_TARGET_MAX_KG=0.20

# Message 2: Gemini coach (after numeric digest). Requires GEMINI_API_KEY.
# GEMINI_ANALYSIS_ENABLED=true
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.5-flash
# ANALYSIS_LOOKBACK_DAYS=28
# USER_GOAL=Lean bulk: +0.10 to +0.20 kg/week on 7d avg weight

# Run sync: python -m garmin_bia_sync  (or ./scripts/run_local.sh)
# Backfill:  python history_pull.py --start YYYY-MM-DD --end YYYY-MM-DD
# Notify:    python history_pull.py --notify --notify-only --report-date YYYY-MM-DD --with-gemini
# Export tokens: python scripts/export_tokens.py
